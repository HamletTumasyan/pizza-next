generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Pizza {
  id          Int          @id @default(autoincrement())
  name        String
  image       String
  descr       String
  price       Decimal      @db.Decimal(10, 2)
  ingridients Ingridient[]
}

model Ingridient {
  id      Int    @id @default(autoincrement())
  name    String
  pizza   Pizza? @relation(fields: [pizzaId], references: [id])
  pizzaId Int?
}
